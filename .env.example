# Telegram API credentials - Get from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE=+1234567890

# Session name (archivo .session que se creara)
SESSION_NAME=torznab_session

# Torznab API key for authenticating clients (Prowlarr/Sonarr/Radarr)
TORZNAB_APIKEY=change_me_to_a_random_string

# Base URL for download/stream links (how clients reach this server)
BASE_URL=http://localhost:9117

# Optional: path to user_channels.json from docker-crawl skill to import channels
USER_CHANNELS_FILE=

# Server port
TORZNAB_PORT=9117

# Download cache directory (share with qBittorrent for instant hash-check)
DOWNLOAD_DIR=./data/cache
